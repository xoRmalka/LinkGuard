# LinkGuard web app — copy to `.env` or `.env.local` (Vite loads both; `.env.local` is usual for secrets).

# Required for sign-in and authenticated scans: Clerk publishable key (Dashboard → API keys → React).
VITE_CLERK_PUBLISHABLE_KEY=

# Optional: full backend base URL in production, e.g. https://api.yourdomain.com
# Leave empty in dev: Vite proxies `/api` to Flask (see `client/vite.config.ts`).
VITE_API_URL=

# Only variables prefixed with VITE_ are exposed to the browser.
