# Optional: Neon / Postgres. If unset, SQLite file server/linkguard.db is used.
DATABASE_URL=

# Clerk: issuer URL from Clerk dashboard (JWT issuer), e.g. https://YOUR-APP.clerk.accounts.dev
CLERK_ISSUER=

GOOGLE_SAFE_BROWSING_API_KEY=

# Comma-separated browser origins allowed to call the API with cookies/Authorization
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
