# LinkGuard API — copy to `.env` and fill in values.

# --- Database ---
# Neon / Postgres connection string. If unset, SQLite is used at `server/linkguard.db`.
# Neon may give `postgres://...`; SQLAlchemy accepts `postgresql://` (both work here).
DATABASE_URL=

# --- Clerk (signed-in API routes) ---
# Must match Dashboard → "Frontend API URL" and the JWT `iss` claim (session tokens).
# Example: https://YOUR-INSTANCE.clerk.accounts.dev
CLERK_ISSUER=

# Strongly recommended: paste "JWKS Public Key" (PEM) from Clerk Dashboard → API keys.
# Multiline PEM in quotes is OK. Or one line with `\n` between PEM lines.
CLERK_JWT_KEY=

# Backend API (lazy default `public_metadata.role`, admin routes). Never expose to Vite.
CLERK_SECRET_KEY=

# --- Integrations ---
# Google Safe Browsing (optional; scans still run without it).
GOOGLE_SAFE_BROWSING_API_KEY=

# --- HTTP ---
# Origins allowed for CORS on `/api/*` (comma-separated, no spaces). Include your Vite URL.
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Note: Guest scan limit (3 / IP / UTC day) and scoring version are set in `app/config.py`, not env.
